# ══════════════════════════════════════════════════════════════════════════════
# Closi AI — Variáveis de Ambiente
# Copie para .env e preencha os valores.
# ══════════════════════════════════════════════════════════════════════════════

# ── OpenRouter / LLM ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
# Opcional — aparecem no dashboard do OpenRouter para analytics
OPENROUTER_SITE_URL=https://closi.ai
OPENROUTER_APP_NAME=Closi AI
MAX_TOKENS=4000

# ── Servidor ──────────────────────────────────────────────────────────────────
DEBUG=false
PORT=5000
HOST=0.0.0.0

# ── Autenticação & Segurança ─────────────────────────────────────────────────
# Bearer token para /chat (se vazio, auth desabilitada)
API_SECRET_TOKEN=
# Segundos de debounce para acumular mensagens rápidas
RESPONSE_DELAY_SECONDS=10
# Mensagem enviada ao lead quando o sistema falha
FALLBACK_MESSAGE=Estou com uma instabilidade agora, em breve um consultor vai te atender.
# Máximo de requests/min no /webhook/form por IP
FORM_RATE_LIMIT=5

# ── Login do Dashboard (Supabase Auth) ───────────────────────────────────────
# Chave secreta para assinar cookies de sessão do Flask.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Duração da sessão após login (em horas)
SESSION_LIFETIME_HOURS=2
# Rate limit de tentativas de login por IP
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=5
# ⚠️ APENAS LOCAL. Se "true", pula o login e libera o dashboard sem autenticação.
# NUNCA definir como true em produção.
AUTH_DISABLED=false

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJhbGci...

# ── Z-API (WhatsApp) ─────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── HubSpot (opcional — desabilitado por padrão) ─────────────────────────────
HUBSPOT_ENABLED=false
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxx
HUBSPOT_PIPELINE_ID=default

# ── Escalação ────────────────────────────────────────────────────────────────
# Telefone do supervisor (com DDI, ex: 5531999999999)
SUPERVISOR_PHONE=
# Botmaker (futuro — transferência direta)
BOTMAKER_API_KEY=
BOTMAKER_TEAM_ID=
